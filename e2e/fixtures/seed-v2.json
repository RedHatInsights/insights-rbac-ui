{
  "$schema": "./seed-schema.json",
  "description": "V2 seed data: roles, groups, and workspaces (full Access Management support)",
  "personas": {
    "admin": { "username": "rbac-e2e-admin-v2" },
    "userviewer": { "username": "rbac-e2e-userviewer-v2" },
    "readonly": { "username": "rbac-e2e-user-v2" }
  },
  "seededUsers": [
    { "username": "rbac-e2e-seed-user" }
  ],
  "roles": [
    {
      "name": "Seeded Role",
      "display_name": "Seeded Role",
      "description": "Controlled test role for search and view tests",
      "permissions": [
        "inventory:hosts:read",
        "inventory:groups:read"
      ]
    },
    {
      "name": "Child Role",
      "display_name": "Child Role",
      "description": "Role for child workspace testing",
      "permissions": [
        "cost-management:cost_model:read"
      ]
    }
  ],
  "groups": [
    {
      "name": "Seeded Group",
      "description": "Controlled test group for search and view tests",
      "roles_list": ["Seeded Role"]
    },
    {
      "name": "Child Group",
      "description": "Group for child workspace testing",
      "roles_list": ["Child Role"]
    }
  ],
  "workspaces": [
    {
      "name": "Seeded Workspace",
      "description": "Controlled test workspace for V2 tests"
    },
    {
      "name": "Seeded Child Workspace",
      "description": "Nested workspace for inheritance testing",
      "parent_id": "Seeded Workspace"
    }
  ],
  "role_bindings": [
    {
      "group": "Seeded Group",
      "role": "Seeded Role",
      "workspace": "Seeded Workspace"
    },
    {
      "group": "Child Group",
      "role": "Child Role",
      "workspace": "Seeded Child Workspace"
    }
  ]
}
